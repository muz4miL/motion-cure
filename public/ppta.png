<style>
  [v-cloak] {
    display: none;
  }

  /* Skip to main content link styles */
  .skip-to-main {
    position: absolute;
    top: -40px;
    left: 6px;
    background: #000;
    color: #fff;
    padding: 8px;
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    font-weight: bold;
    z-index: 9999;
    transition: top 0.3s;
